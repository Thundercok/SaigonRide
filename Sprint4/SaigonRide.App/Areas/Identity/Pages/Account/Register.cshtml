@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="identity-container">
    <div class="identity-card">
        <h1>Create Account</h1>
        <h2>Register to get started</h2>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="error-msg" role="alert"></div>
            
            <div class="input-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="kiosk-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="error-msg"></span>
            </div>
            
            <div class="input-group">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" class="kiosk-input" autocomplete="new-password" aria-required="true" placeholder="Create a password" />
                <span asp-validation-for="Input.Password" class="error-msg"></span>
            </div>
            
            <div class="input-group">
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" class="kiosk-input" autocomplete="new-password" aria-required="true" placeholder="Confirm your password" />
                <span asp-validation-for="Input.ConfirmPassword" class="error-msg"></span>
            </div>
            
            <button id="register-submit" type="submit" class="action-btn btn-primary">Register</button>

            <!-- Cross-link to Login -->
            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="action-btn btn-secondary">Already have an account? Log in</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}