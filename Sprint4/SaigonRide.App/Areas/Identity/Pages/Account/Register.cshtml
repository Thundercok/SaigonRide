@page
@model RegisterModel
@{ ViewData["Title"] = "Create Account"; Layout = "/Views/Shared/_Layout.cshtml"; }

<style>
    /* reuse auth styles from login — copy the same <style> block */
    .auth-wrap {
        min-height: calc(100vh - 60px);
        display: flex; align-items: center; justify-content: center;
        padding: 40px 20px; background: #fafafa;
    }
    .auth-card {
        background: #fff; border: 1px solid #e0e0e0; border-radius: 16px;
        padding: 48px; width: 100%; max-width: 420px;
        box-shadow: 0 4px 24px rgba(0,0,0,.06);
    }
    .auth-logo { font-size: 13px; font-weight: 700; color: #2A5C43; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 8px; }
    .auth-title { font-size: 28px; font-weight: 800; color: #111; margin-bottom: 4px; }
    .auth-sub { font-size: 14px; color: #999; margin-bottom: 32px; }
    .auth-label { display: block; font-size: 12px; font-weight: 700; color: #444; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 6px; }
    .auth-input {
        width: 100%; padding: 12px 14px; border: 2px solid #e0e0e0; border-radius: 8px;
        font-size: 15px; outline: none; transition: border-color .15s; margin-bottom: 4px;
        font-family: 'Inter', sans-serif;
    }
    .auth-input:focus { border-color: #2A5C43; }
    .auth-input.input-validation-error { border-color: #c0392b; }
    .field-validation-error { font-size: 12px; color: #c0392b; display: block; margin-bottom: 12px; }
    .auth-field { margin-bottom: 16px; }
    .auth-btn {
        width: 100%; padding: 14px; background: #2A5C43; color: #fff;
        border: none; border-radius: 8px; font-size: 16px; font-weight: 700;
        cursor: pointer; transition: background .15s; margin-top: 8px;
        font-family: 'Inter', sans-serif;
    }
    .auth-btn:hover { background: #1a3a2a; }
    .auth-link { color: #2A5C43; font-weight: 600; text-decoration: none; }
    .auth-link:hover { text-decoration: underline; }
    .auth-footer { text-align: center; font-size: 14px; color: #666; margin-top: 24px; }
    .alert-danger { background: #fde8e8; color: #c0392b; border-radius: 8px; padding: 12px 16px; font-size: 14px; margin-bottom: 20px; }
    .password-hint { font-size: 11px; color: #999; margin-top: 4px; margin-bottom: 12px; }
    .perks { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 28px; }
    .perk { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #555; }
    .perk-dot { width: 6px; height: 6px; background: #5ddb8a; border-radius: 50%; flex-shrink: 0; }
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo">⚡ SaigonRide</div>
        <div class="auth-title">Create account</div>
        <div class="auth-sub">Start exploring Saigon on two wheels</div>

        <div class="perks">
            <div class="perk"><div class="perk-dot"></div> Free to join</div>
            <div class="perk"><div class="perk-dot"></div> 8 stations</div>
            <div class="perk"><div class="perk-dot"></div> Secure deposit</div>
            <div class="perk"><div class="perk-dot"></div> No app needed</div>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="alert-danger"></div>

            <div class="auth-field">
                <label asp-for="Input.Email" class="auth-label">Email</label>
                <input asp-for="Input.Email" class="auth-input"
                       autocomplete="email" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.Password" class="auth-label">Password</label>
                <input asp-for="Input.Password" class="auth-input"
                       autocomplete="new-password" placeholder="••••••••" />
                <div class="password-hint">Min 8 chars · uppercase · number · symbol</div>
                <span asp-validation-for="Input.Password" class="field-validation-error"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.ConfirmPassword" class="auth-label">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" class="auth-input"
                       autocomplete="new-password" placeholder="••••••••" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
            </div>

            <button id="registerSubmit" type="submit" class="auth-btn">Create Account →</button>
        </form>

        <div class="auth-footer">
            Already have an account?
            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">Sign in</a>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }