@{
    Layout = "_Layout";
    ViewData["Title"] = "SaigonRide — Electric Vehicle Rental";
}

<style>
    * { box-sizing: border-box; }
    .hero {
        background: linear-gradient(135deg, #0f2419 0%, #2A5C43 60%, #1a4a30 100%);
        min-height: 92vh; display: flex; align-items: center;
        padding: 60px 40px; position: relative; overflow: hidden;
    }
    .hero::before {
        content: '';
        position: absolute; inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    .hero-badge { display: inline-block; background: rgba(255,255,255,.12); color: #a8d5b5; padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 24px; border: 1px solid rgba(255,255,255,.15); }
    .hero-title { font-size: clamp(36px, 5vw, 64px); font-weight: 900; color: #fff; line-height: 1.1; margin: 0 0 20px; font-family: 'Helvetica Neue', Arial, sans-serif; }
    .hero-title span { color: #5ddb8a; }
    .hero-desc { font-size: 18px; color: rgba(255,255,255,.7); line-height: 1.6; margin-bottom: 36px; }
    .hero-cta { display: inline-flex; align-items: center; gap: 10px; background: #5ddb8a; color: #0f2419; padding: 16px 32px; border-radius: 8px; font-size: 16px; font-weight: 800; text-decoration: none; transition: transform .15s, box-shadow .15s; }
    .hero-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(93,219,138,.4); color: #0f2419; }
    .hero-cta-secondary { display: inline-flex; align-items: center; gap: 10px; background: transparent; color: #fff; padding: 16px 32px; border-radius: 8px; font-size: 16px; font-weight: 700; text-decoration: none; border: 2px solid rgba(255,255,255,.3); margin-left: 12px; transition: border-color .15s; }
    .hero-cta-secondary:hover { border-color: #fff; color: #fff; }

    .hero-visual { position: relative; }
    .stat-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .stat-card { background: rgba(255,255,255,.08); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,.12); border-radius: 12px; padding: 20px; color: #fff; }
    .stat-num  { font-size: 32px; font-weight: 900; color: #5ddb8a; }
    .stat-label { font-size: 12px; color: rgba(255,255,255,.6); margin-top: 4px; text-transform: uppercase; letter-spacing: 1px; }
    .stat-card.wide { grid-column: 1 / -1; display: flex; align-items: center; gap: 20px; }

    .features { padding: 80px 40px; background: #fafafa; }
    .features-inner { max-width: 1200px; margin: 0 auto; }
    .section-label { font-size: 11px; text-transform: uppercase; letter-spacing: 2px; color: #2A5C43; font-weight: 700; margin-bottom: 12px; }
    .section-title { font-size: clamp(28px, 4vw, 42px); font-weight: 800; color: #111; margin: 0 0 48px; font-family: 'Helvetica Neue', Arial, sans-serif; }
    .feature-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .feature-card { background: #fff; border: 1px solid #e8e8e8; border-radius: 12px; padding: 28px; transition: box-shadow .2s, transform .2s; }
    .feature-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,.08); transform: translateY(-4px); }
    .feature-icon { font-size: 32px; margin-bottom: 16px; }
    .feature-title { font-size: 18px; font-weight: 700; color: #111; margin-bottom: 8px; }
    .feature-desc { font-size: 14px; color: #666; line-height: 1.6; }

    .how-it-works { padding: 80px 40px; background: #fff; }
    .how-inner { max-width: 900px; margin: 0 auto; text-align: center; }
    .steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 48px; position: relative; }
    .steps::before { content: ''; position: absolute; top: 28px; left: 10%; right: 10%; height: 2px; background: linear-gradient(90deg, #2A5C43, #5ddb8a); z-index: 0; }
    .step { position: relative; z-index: 1; }
    .step-num { width: 56px; height: 56px; background: #2A5C43; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 900; margin: 0 auto 16px; }
    .step-title { font-size: 14px; font-weight: 700; color: #111; margin-bottom: 6px; }
    .step-desc { font-size: 12px; color: #999; }

    .vehicles-section { padding: 80px 40px; background: #f5f5f5; }
    .vehicles-inner { max-width: 1200px; margin: 0 auto; }
    .vehicle-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
    .vehicle-card { background: #fff; border-radius: 12px; overflow: hidden; border: 1px solid #e8e8e8; }
    .vehicle-card-header { padding: 32px; text-align: center; font-size: 56px; }
    .grade-a { background: linear-gradient(135deg, #1a3a5c, #2d6a9f); }
    .grade-b { background: linear-gradient(135deg, #2A5C43, #3d8a62); }
    .grade-c { background: linear-gradient(135deg, #444, #666); }
    .vehicle-card-body { padding: 20px 24px 24px; }
    .vehicle-name { font-size: 18px; font-weight: 800; color: #111; margin-bottom: 4px; }
    .vehicle-grade { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #999; margin-bottom: 16px; }
    .vehicle-price { display: flex; justify-content: space-between; align-items: baseline; padding-top: 16px; border-top: 1px solid #f0f0f0; }
    .price-main { font-size: 22px; font-weight: 900; color: #2A5C43; }
    .price-sub { font-size: 12px; color: #999; }

    .cta-section { padding: 80px 40px; background: #111; text-align: center; }
    .cta-title { font-size: clamp(28px, 4vw, 48px); font-weight: 900; color: #fff; margin-bottom: 16px; }
    .cta-desc { font-size: 18px; color: rgba(255,255,255,.6); margin-bottom: 36px; }

    @@media (max-width: 768px) {
        .hero-inner, .feature-grid, .vehicle-cards { grid-template-columns: 1fr; }
        .steps { grid-template-columns: repeat(2, 1fr); }
        .steps::before { display: none; }
        .hero-visual { display: none; }
    }
</style>

<!-- HERO -->
<section class="hero">
    <div class="hero-inner">
        <div>
            <div class="hero-badge">⚡ Ho Chi Minh City</div>
            <h1 class="hero-title">Explore Saigon<br>on <span>Your Terms</span></h1>
            <p class="hero-desc">Electric bikes and scooters at every major landmark. Scan, unlock, ride. No apps, no hassle — just the city.</p>
            <div>
                <a asp-controller="Identity" asp-action="Account/Register" class="hero-cta">
                    Get Started →
                </a>
                <a asp-controller="Kiosk" asp-action="Index" class="hero-cta-secondary">
                    Try Kiosk
                </a>
            </div>
        </div>
        <div class="hero-visual">
            <div class="stat-cards">
                <div class="stat-card">
                    <div class="stat-num">8</div>
                    <div class="stat-label">Stations</div>
                </div>
                <div class="stat-card">
                    <div class="stat-num">24/7</div>
                    <div class="stat-label">Available</div>
                </div>
                <div class="stat-card">
                    <div class="stat-num">15k ₫</div>
                    <div class="stat-label">From / hour</div>
                </div>
                <div class="stat-card">
                    <div class="stat-num">0 ₫</div>
                    <div class="stat-label">Hidden fees</div>
                </div>
                <div class="stat-card wide">
                    <div style="font-size:32px;">🌱</div>
                    <div>
                        <div style="font-weight:700;font-size:15px;">100% Electric Fleet</div>
                        <div style="color:rgba(255,255,255,.5);font-size:13px;">Zero emissions. Zero guilt.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="features">
    <div class="features-inner">
        <div class="section-label">Why SaigonRide</div>
        <h2 class="section-title">Built for the modern<br>city explorer</h2>
        <div class="feature-grid">
            <div class="feature-card">
                <div class="feature-icon">🗺️</div>
                <div class="feature-title">Multi-stop Freedom</div>
                <div class="feature-desc">Pick up at Bến Thành, drop off at Landmark 81. Our network covers every major tourist landmark in District 1.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon">💳</div>
                <div class="feature-title">International Payments</div>
                <div class="feature-desc">Visa, Mastercard, and local VietQR all accepted. Deposit held securely, refunded automatically on return.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon">⚡</div>
                <div class="feature-title">Always Charged</div>
                <div class="feature-desc">Every vehicle is charged and maintained before deployment. Real-time availability shown at every kiosk.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🔒</div>
                <div class="feature-title">Secure Deposit</div>
                <div class="feature-desc">Refundable digital deposit, held atomically. Never charged unless you lose or damage the vehicle.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📧</div>
                <div class="feature-title">No App Required</div>
                <div class="feature-desc">Just your email. Walk up to any kiosk, enter your email, verify with OTP, and you're riding in under 60 seconds.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🛵</div>
                <div class="feature-title">3 Vehicle Classes</div>
                <div class="feature-desc">Standard bikes for casual exploring, e-scooters for speed, VinFast Klara for the full Vietnamese experience.</div>
            </div>
        </div>
    </div>
</section>

<!-- HOW IT WORKS -->
<section class="how-it-works">
    <div class="how-inner">
        <div class="section-label">Process</div>
        <h2 class="section-title">Ready to ride in 4 steps</h2>
        <div class="steps">
            <div class="step">
                <div class="step-num">1</div>
                <div class="step-title">Find a Kiosk</div>
                <div class="step-desc">At any major landmark in District 1</div>
            </div>
            <div class="step">
                <div class="step-num">2</div>
                <div class="step-title">Verify Email</div>
                <div class="step-desc">OTP sent instantly to your inbox</div>
            </div>
            <div class="step">
                <div class="step-num">3</div>
                <div class="step-title">Pay Deposit</div>
                <div class="step-desc">VietQR or international card</div>
            </div>
            <div class="step">
                <div class="step-num">4</div>
                <div class="step-title">Ride & Return</div>
                <div class="step-desc">Drop off at any station, deposit refunded</div>
            </div>
        </div>
    </div>
</section>

<!-- VEHICLES -->
<section class="vehicles-section">
    <div class="vehicles-inner">
        <div class="section-label">Fleet</div>
        <h2 class="section-title">Choose your ride</h2>
        <div class="vehicle-cards">
            <div class="vehicle-card">
                <div class="vehicle-card-header grade-c">🚲</div>
                <div class="vehicle-card-body">
                    <div class="vehicle-name">Standard Bike</div>
                    <div class="vehicle-grade">Grade C · Eco Pick</div>
                    <div class="vehicle-price">
                        <span class="price-main">15,000 ₫</span>
                        <span class="price-sub">/ hour · Deposit 10%</span>
                    </div>
                </div>
            </div>
            <div class="vehicle-card">
                <div class="vehicle-card-header grade-b">⚡</div>
                <div class="vehicle-card-body">
                    <div class="vehicle-name">E-Scooter City</div>
                    <div class="vehicle-grade">Grade B · Most Popular</div>
                    <div class="vehicle-price">
                        <span class="price-main">35,000 ₫</span>
                        <span class="price-sub">/ hour · Deposit 15%</span>
                    </div>
                </div>
            </div>
            <div class="vehicle-card">
                <div class="vehicle-card-header grade-a">🛵</div>
                <div class="vehicle-card-body">
                    <div class="vehicle-name">VinFast Klara S</div>
                    <div class="vehicle-grade">Grade A · Premium</div>
                    <div class="vehicle-price">
                        <span class="price-main">60,000 ₫</span>
                        <span class="price-sub">/ hour · Deposit 20%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta-section">
    <h2 class="cta-title">Ready to ride Saigon?</h2>
    <p class="cta-desc">Register in 30 seconds. First ride waiting at Bến Thành.</p>
    <a asp-area="Identity" asp-page="/Account/Register" class="hero-cta" style="font-size:18px;padding:18px 40px;">
        Create Free Account →
    </a>
</section>