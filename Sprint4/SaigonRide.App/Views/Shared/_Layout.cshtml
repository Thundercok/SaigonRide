<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SaigonRide</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#2A5C43" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: #fafafa; color: #111; margin: 0; }

        /* ── Navbar ── */
        .sg-nav {
            position: sticky; top: 0; z-index: 1000;
            background: rgba(255,255,255,.92); backdrop-filter: blur(12px);
            border-bottom: 1px solid #e8e8e8;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 40px; height: 60px;
        }
        .sg-logo {
            font-weight: 900; font-size: 18px; color: #2A5C43;
            text-decoration: none; letter-spacing: -0.5px; display: flex; align-items: center; gap: 8px;
        }
        .sg-logo-dot { width: 8px; height: 8px; background: #5ddb8a; border-radius: 50%; }
        .sg-nav-links { display: flex; align-items: center; gap: 4px; }
        .sg-nav-link {
            padding: 6px 14px; border-radius: 6px; font-size: 14px; font-weight: 500;
            color: #444; text-decoration: none; transition: background .15s, color .15s;
        }
        .sg-nav-link:hover { background: #f0f0f0; color: #111; }
        .sg-nav-link.active { background: #f0f7f3; color: #2A5C43; font-weight: 600; }
        .sg-nav-actions { display: flex; align-items: center; gap: 8px; }
        .sg-btn-ghost {
            padding: 7px 16px; border-radius: 6px; font-size: 14px; font-weight: 600;
            color: #444; text-decoration: none; border: 1.5px solid #e0e0e0;
            transition: border-color .15s, color .15s;
        }
        .sg-btn-ghost:hover { border-color: #2A5C43; color: #2A5C43; }
        .sg-btn-primary {
            padding: 7px 16px; border-radius: 6px; font-size: 14px; font-weight: 700;
            color: #fff; background: #2A5C43; text-decoration: none;
            transition: background .15s;
        }
        .sg-btn-primary:hover { background: #1a3a2a; color: #fff; }

        /* ── Mobile hamburger ── */
        .sg-hamburger { display: none; background: none; border: none; cursor: pointer; padding: 4px; }
        .sg-hamburger span { display: block; width: 22px; height: 2px; background: #111; margin: 5px 0; border-radius: 2px; transition: .3s; }

        @@media (max-width: 768px) {
            .sg-nav { padding: 0 20px; }
            .sg-nav-links, .sg-nav-actions { display: none; }
            .sg-hamburger { display: block; }
        }

        /* ── Footer ── */
        .sg-footer {
            background: #111; color: rgba(255,255,255,.5);
            padding: 48px 40px 32px; margin-top: 80px;
        }
        .sg-footer-inner { max-width: 1200px; margin: 0 auto; }
        .sg-footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 40px; }
        .sg-footer-logo { font-weight: 900; font-size: 20px; color: #fff; margin-bottom: 12px; }
        .sg-footer-desc { font-size: 13px; line-height: 1.6; }
        .sg-footer-heading { font-size: 11px; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,.3); margin-bottom: 16px; font-weight: 700; }
        .sg-footer-link { display: block; color: rgba(255,255,255,.5); text-decoration: none; font-size: 13px; margin-bottom: 8px; transition: color .15s; }
        .sg-footer-link:hover { color: #fff; }
        .sg-footer-bottom { border-top: 1px solid rgba(255,255,255,.08); padding-top: 24px; display: flex; justify-content: space-between; font-size: 12px; }

        @@media (max-width: 768px) {
            .sg-footer-grid { grid-template-columns: 1fr 1fr; }
            .sg-footer { padding: 40px 20px 24px; margin-top: 40px; }
        }
    </style>
</head>
<body>

<!-- Navbar -->
<nav class="sg-nav">
    <a asp-controller="Home" asp-action="Index" class="sg-logo">
        <div class="sg-logo-dot"></div>
        SaigonRide
    </a>

    <div class="sg-nav-links">
        <a asp-controller="Home" asp-action="Index" class="sg-nav-link">Home</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Dashboard" asp-action="Index" class="sg-nav-link">Dashboard</a>
            <a asp-controller="Wallet"    asp-action="Index" class="sg-nav-link">💳 Wallet</a>
            <a asp-controller="Kiosk"     asp-action="Index" class="sg-nav-link">Kiosk</a>
            <a asp-controller="Stations" asp-action="Index" class="sg-nav-link">🗺 Stations</a>
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Index" class="sg-nav-link">⚙️ Admin</a>
            }
        }
    </div>

    <div class="sg-nav-actions">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <span style="font-size:13px;color:#666;margin-right:4px;">@User.Identity.Name</span>
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" style="margin:0;">
                <button type="submit" class="sg-btn-ghost" style="cursor:pointer;background:none;">Sign out</button>
            </form>
        }
        else
        {
            <a asp-area="Identity" asp-page="/Account/Login"    class="sg-btn-ghost">Log in</a>
            <a asp-area="Identity" asp-page="/Account/Register" class="sg-btn-primary">Sign up</a>
        }
    </div>

    <button class="sg-hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
    </button>
</nav>

<!-- Content -->
<main>
    @RenderBody()
</main>

<!-- Footer -->
<footer class="sg-footer">
    <div class="sg-footer-inner">
        <div class="sg-footer-grid">
            <div>
                <div class="sg-footer-logo">⚡ SaigonRide</div>
                <div class="sg-footer-desc">Electric vehicle rental for the modern city explorer. Built for foreign tourists discovering Ho Chi Minh City.</div>
            </div>
            <div>
                <div class="sg-footer-heading">Product</div>
                <a asp-controller="Kiosk" asp-action="Index" class="sg-footer-link">Kiosk</a>
                <a asp-controller="Dashboard" asp-action="Index" class="sg-footer-link">Dashboard</a>
                <a asp-controller="Wallet" asp-action="Index" class="sg-footer-link">Wallet</a>
            </div>
            <div>
                <div class="sg-footer-heading">Fleet</div>
                <a class="sg-footer-link" href="#">Standard Bike</a>
                <a class="sg-footer-link" href="#">E-Scooter</a>
                <a class="sg-footer-link" href="#">VinFast Klara S</a>
            </div>
            <div>
                <div class="sg-footer-heading">Company</div>
                <a class="sg-footer-link" href="#">About</a>
                <a class="sg-footer-link" href="#">Contact</a>
                <a asp-controller="Home" asp-action="Privacy" class="sg-footer-link">Privacy</a>
            </div>
        </div>
        <div class="sg-footer-bottom">
            <span>© @DateTime.Now.Year SaigonRide. All rights reserved.</span>
            <span>Ho Chi Minh City, Vietnam 🇻🇳</span>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>