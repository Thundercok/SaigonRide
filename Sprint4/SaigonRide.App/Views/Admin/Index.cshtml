@{
Layout = "_Layout";
ViewData["Title"] = "Admin Command Center";
}

<style>
    /* Admin-specific Swiss Design */
    .admin-container { max-width: 1200px; margin: 0 auto; padding: 20px; font-family: 'Helvetica Neue', Arial, sans-serif; }
    .metric-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 40px; }
    .metric-card { background: #111; color: #fff; padding: 20px; border-radius: 8px; }
    .metric-title { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: #aaa; }
    .metric-value { font-size: 36px; font-weight: bold; margin-top: 10px; }

    .data-table { width: 100%; border-collapse: collapse; margin-bottom: 40px; background: #fff; border: 1px solid #e0e0e0; }
    .data-table th, .data-table td { padding: 15px; text-align: left; border-bottom: 1px solid #e0e0e0; }
    .data-table th { background: #f8f9fa; font-size: 12px; text-transform: uppercase; color: #666; }

    .btn-sm { padding: 8px 12px; font-size: 12px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; }
    .btn-danger { background: #D32F2F; color: white; }
    .btn-warning { background: #F57C00; color: white; }
</style>

<div class="admin-container">
    <h1 style="margin-bottom: 30px; border-bottom: 3px solid #111; padding-bottom: 10px;">Command Center</h1>

    <!-- TOP METRICS -->
    <div class="metric-grid">
        <div class="metric-card">
            <div class="metric-title">Daily Fare Revenue</div>
            <div class="metric-value">@string.Format("{0:N0} ₫", ViewBag.DailyRevenue)</div>
        </div>
        <div class="metric-card" style="background: #2A5C43;">
            <div class="metric-title">Active Rentals</div>
            <div class="metric-value">@((ViewBag.ActiveRentals as IEnumerable<dynamic>).Count())</div>
        </div>
    </div>

    <!-- STATION FLEET VIEW -->
    <h3>Station Fleet Status</h3>
    <table class="data-table">
        <thead>
        <tr>
            <th>Station ID</th>
            <th>Name</th>
            <th>Available Bikes</th>
            <th>Total Capacity</th>
            <th>Status</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var station in ViewBag.Stations)
        {
        <tr>
            <td>@station.Id</td>
            <td><strong>@station.Name</strong></td>
            <td>@station.AvailableBikes</td>
            <td>@station.Capacity</td>
            <td>
                @if(station.AvailableBikes == 0) { <span style="color: #D32F2F; font-weight:bold;">Empty</span> }
                else if (station.AvailableBikes == station.Capacity) { <span style="color: #F57C00; font-weight:bold;">Full</span> }
                else { <span style="color: #2A5C43; font-weight:bold;">Optimal</span> }
            </td>
        </tr>
        }
        </tbody>
    </table>

    <!-- ACTIVE RENTALS -->
    <h3>Live Rentals</h3>
    <table class="data-table">
        <thead>
        <tr>
            <th>Rental ID</th>
            <th>User ID</th>
            <th>Vehicle</th>
            <th>Start Time</th>
            <th>Origin Station</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var r in ViewBag.ActiveRentals)
        {
        <tr id="rental-row-@r.Id">
            <td>#@r.Id</td>
            <td>@r.UserId</td>
            <td>@r.Vehicle.LicensePlate</td>
            <td>@r.StartTime?.ToString("HH:mm:ss")</td>
            <td>@r.StartStation.Name</td>
            <td>
                <button class="btn-sm btn-danger" onclick="forceEndRental(@r.Id)">Force End</button>
            </td>
        </tr>
        }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    async function forceEndRental(rentalId) {
        if (!confirm("WARNING: This will instantly end the rental and waive the fare. Proceed?")) return;

        try {
            const res = await fetch(`/Admin/ForceEndRental/${rentalId}`, { method: 'POST' });
            if (res.ok) {
                // Instantly remove the row from the table to keep DOM snappy
                document.getElementById(`rental-row-${rentalId}`).remove();
                alert("Rental ended successfully.");
            } else {
                alert("Failed to end rental.");
            }
        } catch (e) {
            console.error(e);
        }
    }
</script>
}