@model SaigonRide.App.Models.ViewModels.DashboardViewModel
@{
    Layout = "_Layout"; // Assuming you have a standard layout linking identity
    ViewData["Title"] = "My RideCard";
}

<!-- Link our specific mobile CSS -->
<link rel="stylesheet" href="~/css/swiss-mobile.css" />

<div class="app-container">
    <div class="brand-header">
        🚇 SAIGONRIDE
    </div>

    <!-- WALLET SECTION -->
    <div class="swiss-card">
        <h2>Virtual RideCard</h2>
        <div class="balance-display" id="walletBalance">-- VND</div>
        <button class="btn btn-outline" onclick="topUpWallet()">+ Top Up Balance</button>
    </div>

    <!-- ACTIVE RIDE SECTION (Hidden by default) -->
    <div id="activeRideView" class="swiss-card hidden">
        <h2>Current Ride</h2>
        <div style="text-align: center; margin: 30px 0;">
            <div style="font-size: 14px; color: #666;">Elapsed Time</div>
            <div id="rideTimer" style="font-size: 48px; font-weight: bold; color: var(--primary);">00:00</div>
        </div>
        <button class="btn btn-danger" onclick="stopRide()">End Ride & Pay</button>
    </div>

    <!-- STATION LIST SECTION -->
    <div id="stationView" class="swiss-card">
        <h2>Nearby Stations</h2>
        <ul class="station-list">
            @if (Model.Stations != null && Model.Stations.Any())
            {
                foreach (var station in Model.Stations)
                {
                    <li class="station-item">
                        <div class="station-info">
                            <h3>@station.Name</h3>
                            <p>@station.AvailableBikes bikes available</p>
                        </div>
                        <div>
                            <!-- In a real app, user taps station to see bikes. We shortcut to rent the first available bike for the demo -->
                            @if (station.AvailableBikes > 0)
                            {
                                <button class="btn btn-primary" style="padding: 10px 20px;" 
                                        onclick="startRide(@station.Id, @station.FirstAvailableVehicleId)">
                                    Rent
                                </button>
                            }
                            else
                            {
                                <span style="color: var(--danger); font-weight: bold;">Empty</span>
                            }
                        </div>
                    </li>
                }
            }
            else
            {
                <li class="station-item">No stations found nearby.</li>
            }
        </ul>
    </div>
</div>

@section Scripts {
    <script src="~/js/saigon-ride.js"></script>
}