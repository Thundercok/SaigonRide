using Microsoft.AspNetCore.Mvc.RazorPages;
using SaigonRide.App.Helpers;

namespace SaigonRide.App.Pages
{
    public class VNPayReturnModel : PageModel
    {
        private readonly IConfiguration _configuration;

        // Biến để đưa dữ liệu ra ngoài HTML
        public bool IsSuccess { get; set; }
        public string Message { get; set; } = "";
        public string TransactionId { get; set; } = "";
        public string Amount { get; set; } = "";

        public VNPayReturnModel(IConfiguration configuration)
        {
            _configuration = configuration;
        }

        public void OnGet()
        {
            var vnpayData = Request.Query;
            var vnpay = new VnPayLibrary();

            // 1. Quét tất cả tham số trả về bắt đầu bằng "vnp_"
            foreach (var (key, value) in vnpayData)
            {
                if (!string.IsNullOrEmpty(key) && key.StartsWith("vnp_"))
                {
                    vnpay.AddResponseData(key, value.ToString());
                }
            }

            // 2. Lấy HashSecret từ appsettings và vnp_SecureHash từ url
            var vnp_HashSecret = _configuration["VnPay:HashSecret"] ?? "";
            var vnp_SecureHash = Request.Query["vnp_SecureHash"].ToString();

            // 3. Kiểm tra chữ ký bảo mật
            bool checkSignature = vnpay.ValidateSignature(vnp_SecureHash, vnp_HashSecret);

            if (checkSignature)
            {
                var vnp_ResponseCode = vnpay.GetResponseData("vnp_ResponseCode");
                if (vnp_ResponseCode == "00") // 00 là mã thành công của VNPay
                {
                    IsSuccess = true;
                    TransactionId = vnpay.GetResponseData("vnp_TransactionNo");
                    
                    // VNPay trả về số tiền đã nhân 100, nên mình phải chia lại
                    var rawAmount = vnpay.GetResponseData("vnp_Amount");
                    if(long.TryParse(rawAmount, out long parsedAmount))
                    {
                        Amount = (parsedAmount / 100).ToString("N0");
                    }
                }
                else
                {
                    IsSuccess = false;
                    Message = $"Giao dịch bị hủy hoặc lỗi. Mã lỗi: {vnp_ResponseCode}";
                }
            }
            else
            {
                IsSuccess = false;
                Message = "Chữ ký không hợp lệ! Dữ liệu có dấu hiệu bị can thiệp.";
            }
        }
    }
}