@model SaigonRide.App.Models.Entities.Station

<div class="info-panel">

    <!-- Brand -->
    <div class="brand-header">⚡ SAIGONRIDE</div>

    <!-- Clock -->
    <div class="panel-clock">
        <div class="panel-clock-time" id="panelClock">--:--:--</div>
        <div class="panel-clock-date" id="panelDate">—</div>
    </div>

    <!-- Station -->
    <div class="location-context" style="margin-bottom: 14px;">
        <span class="hub-label">📍 @Model.Name</span>
        <span class="status-badge">Trạm #@Model.Id · Đang hoạt động</span>
    </div>

    <!-- Live Stats -->
    <div class="panel-live-stats" id="panelStats">
        <div class="panel-stat">
            <div class="panel-stat-value green" id="statAvailable">—</div>
            <div class="panel-stat-label">Xe sẵn sàng</div>
        </div>
        <div class="panel-stat">
            <div class="panel-stat-value" id="statCapacity">@Model.Capacity</div>
            <div class="panel-stat-label">Tổng dock</div>
        </div>
    </div>

    <!-- Map -->
    <div class="map-container">
        <div class="map-header">
            <h3 class="map-title">Sơ Đồ Trạm</h3>
            <div class="map-legend">
                <span class="pulse-dot"></span> Kiosk
            </div>
        </div>

        <div class="map-visual">
            <svg viewBox="0 0 300 380" class="station-map" preserveAspectRatio="xMidYMid meet">
                <!-- Floor -->
                <rect x="10" y="10" width="280" height="360" rx="16" fill="#f8fafc" stroke="#e2e8f0" stroke-width="2"/>

                <!-- Walkways -->
                <path d="M 10 130 L 290 130" stroke="#ffffff" stroke-width="28"/>
                <path d="M 150 10 L 150 370" stroke="#ffffff" stroke-width="36"/>

                <!-- Dock rows -->
                <g fill="#cbd5e1">
                    <rect x="35" y="45"  width="42" height="18" rx="4"/>
                    <rect x="35" y="72"  width="42" height="18" rx="4"/>
                    <rect x="35" y="160" width="42" height="18" rx="4"/>
                    <rect x="35" y="187" width="42" height="18" rx="4"/>
                    <rect x="35" y="214" width="42" height="18" rx="4"/>
                </g>
                <g fill="#94a3b8">
                    <rect x="223" y="45"  width="42" height="18" rx="4"/>
                    <rect x="223" y="72"  width="42" height="18" rx="4"/>
                    <rect x="223" y="160" width="42" height="18" rx="4"/>
                    <rect x="223" y="187" width="42" height="18" rx="4"/>
                </g>

                <!-- Hub building -->
                <rect x="175" y="255" width="95" height="100" rx="8" fill="#e2e8f0" stroke="#cbd5e1" stroke-width="1.5"/>
                <text x="222" y="310" font-family="system-ui,sans-serif" font-size="13" fill="#64748b" text-anchor="middle" font-weight="700">HUB</text>
                <rect x="195" y="330" width="20" height="25" rx="3" fill="#94a3b8"/>

                <!-- Kiosk marker (animated) -->
                <g transform="translate(96, 215)">
                    <circle cx="0" cy="0" r="22" fill="rgba(0,102,255,0.12)">
                        <animate attributeName="r"       values="12;28;12" dur="2.5s" repeatCount="indefinite"/>
                        <animate attributeName="opacity" values="1;0;1"    dur="2.5s" repeatCount="indefinite"/>
                    </circle>
                    <circle cx="0" cy="0" r="10" fill="#0066ff" stroke="#fff" stroke-width="3"/>
                    <rect   x="-28" y="-40" width="56" height="22" rx="5" fill="#1e293b"/>
                    <text   x="0" y="-25" font-family="system-ui,sans-serif" font-size="10" fill="#fff" text-anchor="middle" font-weight="700">KIOSK</text>
                    <polygon points="-6,-18 6,-18 0,-10" fill="#1e293b"/>
                </g>

                <!-- Dock labels -->
                <text x="56" y="105" font-family="system-ui,sans-serif" font-size="9" fill="#94a3b8" text-anchor="middle">BIKES</text>
                <text x="244" y="105" font-family="system-ui,sans-serif" font-size="9" fill="#94a3b8" text-anchor="middle">SCOOT</text>
            </svg>
        </div>

        <div class="map-footer">📍 Quét mã tại dock để nhận xe</div>
    </div>
</div>

<script>
(function() {
    // ── Panel clock ───────────────────────────────────────────────────────────
    const DAYS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const MONS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    function tickPanel() {
        const now = new Date();
        const tc  = document.getElementById('panelClock');
        const td  = document.getElementById('panelDate');
        if (tc) tc.textContent = now.toLocaleTimeString('vi-VN', { hour12: false });
        if (td) td.textContent = `${DAYS[now.getDay()]} ${now.getDate()} ${MONS[now.getMonth()]}`;
    }
    tickPanel();
    setInterval(tickPanel, 1000);

    // ── Live vehicle count ────────────────────────────────────────────────────
    const stationId = document.getElementById('kioskRoot')?.dataset.stationId;

    async function refreshStats() {
        try {
            const res  = await fetch(`/api/vehicles?stationId=${stationId}`, {
                headers: { 'Authorization': `Bearer ${window.KioskState?.kioskToken ?? ''}` }
            });
            if (!res.ok) return;
            const data = await res.json();
            const el   = document.getElementById('statAvailable');
            if (el) {
                el.textContent = data.length;
                el.className   = 'panel-stat-value ' + (data.length > 0 ? 'green' : 'orange');
            }
        } catch { /* silent */ }
    }

    // Wait for kiosk token to be available before first fetch
    const waitForToken = setInterval(() => {
        if (window.KioskState?.kioskToken) {
            clearInterval(waitForToken);
            refreshStats();
            setInterval(refreshStats, 30000); // refresh every 30s
        }
    }, 500);
})();
</script>