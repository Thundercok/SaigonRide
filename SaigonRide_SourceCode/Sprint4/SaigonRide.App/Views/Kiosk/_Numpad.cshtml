@model string

<div class="numpad">
    <button class="numpad-key" data-target="@Model" data-val="1">1</button>
    <button class="numpad-key" data-target="@Model" data-val="2">2</button>
    <button class="numpad-key" data-target="@Model" data-val="3">3</button>
    <button class="numpad-key" data-target="@Model" data-val="4">4</button>
    <button class="numpad-key" data-target="@Model" data-val="5">5</button>
    <button class="numpad-key" data-target="@Model" data-val="6">6</button>
    <button class="numpad-key" data-target="@Model" data-val="7">7</button>
    <button class="numpad-key" data-target="@Model" data-val="8">8</button>
    <button class="numpad-key" data-target="@Model" data-val="9">9</button>
    <button class="numpad-key numpad-clear" data-target="@Model" data-val="clear">C</button>
    <button class="numpad-key" data-target="@Model" data-val="0">0</button>
    <button class="numpad-key numpad-back" data-target="@Model" data-val="back">⌫</button>
</div>