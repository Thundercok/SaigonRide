@{
    ViewData["Title"] = "Security";
    var totpEnabled = (bool)ViewBag.TotpEnabled;
}

<div style="max-width:600px;margin:48px auto;padding:0 24px;font-family:'Inter',sans-serif;">
    <h1 style="font-size:22px;font-weight:900;margin-bottom:8px;">Security</h1>
    <p style="color:#999;font-size:13px;margin-bottom:32px;">Manage two-factor authentication for your account.</p>

    <div style="border:1px solid #e8e8e8;border-radius:12px;padding:24px;">
        <div style="display:flex;justify-content:space-between;align-items:center;">
            <div>
                <div style="font-weight:700;font-size:15px;">Authenticator App (TOTP)</div>
                <div style="font-size:13px;color:#999;margin-top:4px;">
                    @(totpEnabled ? "Enabled — your account is protected." : "Not enabled.")
                </div>
            </div>
            @if (totpEnabled)
            {
                <form asp-action="Disable" method="post">
                    <button style="padding:8px 18px;background:#fde8e8;color:#c0392b;border:none;border-radius:8px;font-weight:700;cursor:pointer;">
                        Disable
                    </button>
                </form>
            }
            else
            {
                <a asp-action="Setup"
                   style="padding:8px 18px;background:#2A5C43;color:#fff;border-radius:8px;font-weight:700;text-decoration:none;">
                    Enable
                </a>
            }
        </div>
    </div>
</div>